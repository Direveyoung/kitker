# Database (Neon Postgres)
DATABASE_URL=postgresql://neondb_owner:xxxxx@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Auth.js v5 (Magic Link via Resend)
AUTH_SECRET=                            # openssl rand -base64 32
AUTH_RESEND_KEY=                        # Resend API key (re_xxxxx)
AUTH_RESEND_FROM=onboarding@resend.dev  # 검증된 도메인 이메일 (테스트는 resend.dev OK)

# Anthropic (Phase 2 — 클로이 챗)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Calendar (Phase 2)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
