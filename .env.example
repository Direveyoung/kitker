# Database (SQLite · toy2 셀프호스팅, 별도 DB 서비스 불필요)
# 미설정 시 ./data/kitker.db 자동 생성
# EVE_DB_PATH=/absolute/path/kitker.db

# Phase 4까지 인증 비활성 — dev user 하드코딩
EVE_DEV_USER_ID=00000000-0000-0000-0000-000000000001
EVE_AUTH_ENABLED=false

# App (배포 도메인: calendar.kitker.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 배포 시: NEXT_PUBLIC_APP_URL=https://calendar.kitker.com

# ── Phase 2+ (추후 활성화) ──────────────────────────────
# Anthropic (Chloé 챗)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Calendar 양방향
# GOOGLE_CLIENT_ID=xxxxx
# GOOGLE_CLIENT_SECRET=xxxxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ClickUp 동기화
# CLICKUP_API_TOKEN=pk_xxxxx

# Vercel Blob (이미지 업로드)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# ── Phase 4 (인증) ──────────────────────────────────────
# AUTH_SECRET=                # openssl rand -base64 32
# AUTH_RESEND_KEY=re_xxxxx
# AUTH_RESEND_FROM=onboarding@resend.dev
# AUTH_URL=https://kitker.vercel.app

# 웹푸시 알림 (VAPID — `node -e "console.log(require('web-push').generateVAPIDKeys())"` 로 생성)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# KITKER_VAPID_PRIVATE=
# KITKER_VAPID_SUBJECT=mailto:pm.younga@gmail.com
# KITKER_REMINDER_LOOKAHEAD=30   # 일정 시작 N분 전 알림 (기본 30)
